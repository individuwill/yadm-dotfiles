#!/bin/sh
# yadm bootstrap — entry point. Delegates to OS-specific script, then common.
# Re-run any time with: yadm bootstrap

set -e

DIR="$HOME/.config/yadm/bootstrap.d"

os_status=0
case "$(uname -s)" in
  Darwin)
    [ -x "$DIR/darwin" ] && { "$DIR/darwin" || os_status=$?; }
    ;;
  Linux)
    [ -x "$DIR/linux"  ] && { "$DIR/linux"  || os_status=$?; }
    ;;
  *)
    echo "bootstrap: unsupported OS '$(uname -s)' — skipping OS-specific install" >&2
    ;;
esac

# Run common regardless of OS-specific status (decrypt, refresh alt, reminders).
[ -x "$DIR/common" ] && "$DIR/common"

exit "$os_status"
